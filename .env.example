# OnDevice Scholar RAG — Environment Configuration Template
# Copy this file to .env and fill in all required values before starting the server.
#
#   cp .env.example .env
#
# Required fields (no default): server will refuse to start if any are missing.

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=<your-secret-key-at-least-32-chars>

# ── Admin credentials ─────────────────────────────────────────────────────────
ADMIN_USERNAME=<your-admin-username>
ADMIN_PASSWORD=<your-strong-admin-password>

# ── Optional overrides (safe defaults exist in config.py) ─────────────────────
# GENERATION_MODEL_ID=Qwen/Qwen2.5-3B-Instruct
# LOAD_IN_4BIT=true
# GENERATION_MAX_NEW_TOKENS=512
# GENERATION_DO_SAMPLE=false
# GENERATION_TEMPERATURE=0.1

# EMBEDDING_MODEL_ID=BAAI/bge-small-en-v1.5
# EMBEDDING_DIM=384

# RETRIEVAL_TOP_K=5
# RETRIEVAL_SCORE_THRESHOLD=0.30
# RETRIEVAL_FALLBACK_SCORE_THRESHOLD=0.20
# RETRIEVAL_SCORE_GAP=0.25
# CITATION_MIN_SCORE=0.65
# CITATION_INJECTION_MIN_OVERLAP=0.15

# CHUNK_SIZE=1024
# CHUNK_OVERLAP=128

# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=480
